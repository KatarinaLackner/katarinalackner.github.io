{
  "name": "@angi/one-design-system",
  "version": "0.5.0",
  "type": "module",
  "description": "One Design System - A comprehensive design system for Angi and Instapro brands",
  "sideEffects": false,
  "exports": {
    "./tokens": {
      "import": {
        "types": "./dist/tokens/js/index.d.ts",
        "default": "./dist/tokens/js/index.js"
      }
    },
    "./tokens/contract": {
      "import": {
        "types": "./dist/tokens/js/contract.d.ts",
        "default": "./dist/tokens/js/contract.js"
      }
    },
    "./tokens/tokens": {
      "import": {
        "types": "./dist/tokens/js/tokens.d.ts",
        "default": "./dist/tokens/js/tokens.js"
      }
    },
    "./tokens/css/angi.css": "./dist/tokens/css/angi.css",
    "./tokens/css/instapro.css": "./dist/tokens/css/instapro.css",
    "./themes/tailwind-v3": {
      "import": {
        "types": "./dist/themes/tailwind-v3/index.d.ts",
        "default": "./dist/themes/tailwind-v3/index.js"
      }
    },
    "./themes/tailwind-v4/theme.css": "./dist/themes/tailwind-v4/theme.css",
    "./themes/vanilla-extract": {
      "import": {
        "types": "./dist/themes/vanilla-extract/index.d.ts",
        "default": "./dist/themes/vanilla-extract/index.js"
      }
    },
    "./themes/vanilla-extract/contract": {
      "import": {
        "types": "./dist/themes/vanilla-extract/contract.d.ts",
        "default": "./dist/themes/vanilla-extract/contract.css.ts"
      }
    },
    "./themes/vanilla-extract/theme": {
      "import": {
        "types": "./dist/themes/vanilla-extract/theme.d.ts",
        "default": "./dist/themes/vanilla-extract/theme.css.ts"
      }
    },
    "./components/*": {
      "import": {
        "types": "./dist/components/es/*/index.d.ts",
        "default": "./dist/components/es/*/index.js"
      },
      "require": {
        "types": "./dist/components/cjs/*/index.d.ts",
        "default": "./dist/components/cjs/*/index.js"
      }
    },
    "./css-reset/globalReset.css": "./dist/css-reset/globalReset.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "nx build one-design-system",
    "aggregate": "tsx scripts/aggregate.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@gitlab.com/angi1/engineering/one-design-system.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://gitlab.com/angi1/engineering/one-design-system/issues"
  },
  "homepage": "https://gitlab.com/angi1/engineering/one-design-system#readme",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@vanilla-extract/css": "^1.17.4"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
